# multifn-c on Hyperlight — a C test binary for the multi-function
# dispatch plumbing. The kernel's `hyperlight_dispatch_inner` now
# surfaces the in-flight FunctionCall bytes to user mode via
# HL_FC_BYTES_PTR / HL_FC_LEN_PTR env vars; this binary reads them,
# parses the FunctionCall FlatBuffer, and prints which named function
# the host called.
#
# `just run` uses the companion test binary in host/src/bin/
# (multifn-test) which drives the guest via Sandbox::call_named().

set windows-shell := ["powershell.exe", "-NoLogo", "-Command"]
export DOCKER_BUILDKIT := "0"

kernel    := ".unikraft/build/multifn-c-hyperlight_hyperlight-x86_64"
initrd    := "multifn-c-initrd.cpio"
image     := "multifn-c-hyperlight"

run:
    cargo run -q --manifest-path ../../host/Cargo.toml \
        --bin multifn-test -- {{kernel}} {{initrd}}

rootfs:
    docker build --platform linux/amd64 --target cpio -t {{image}}-cpio .
    - docker rm -f {{image}}-tmp
    docker create --name {{image}}-tmp {{image}}-cpio /bin/true
    docker cp {{image}}-tmp:/output.cpio ./{{initrd}}
    docker rm -f {{image}}-tmp

[unix]
build:
    -kraft-hyperlight build --plat hyperlight --arch x86_64

[unix]
clean:
    rm -rf .unikraft {{initrd}}
